{
  "name": "yournextaway",
  "version": "1.0.0",
  "main": "index.ts",
  "private": true,
  "scripts": {
    "dev": "cross-env EXPO_NO_TELEMETRY=1 npx expo start -c",
    "android": "cross-env EXPO_NO_TELEMETRY=1 npx expo start --android -c",
    "ios": "cross-env EXPO_NO_TELEMETRY=1 npx expo start --ios -c",
    "web": "cross-env EXPO_NO_TELEMETRY=1 npx expo start --web -c",
    "devclient": "cross-env EXPO_NO_TELEMETRY=1 npx expo start --dev-client --clear",
    "build:web": "npx expo export -p web && npx workbox generateSW workbox-config.js",
    "prebuild:android": "npx expo prebuild -p android",
    "eas:build:android": "npx eas build -p android",
    "lint": "eslint .",
    "validate:data": "node scripts/validation/validate-data-coverage.cjs",
    "validate:commercial": "node scripts/validation/validate-commercial-integrity.cjs",
    "validate": "node scripts/validation/validate-all.cjs"
  },
