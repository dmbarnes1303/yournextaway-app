# ------------------------------
# YourNextAway Backend ENV file
# ------------------------------
# Copy this file to `.env`
# and fill in your credentials
# ------------------------------

# ===============================
# Server
# ===============================

PORT=3000
NODE_ENV=development

# Comma-separated list
# Example:
# APP_CORS_ORIGINS=http://localhost:8081,http://localhost:3000
APP_CORS_ORIGINS=

# ===============================
# API-Football
# ===============================

API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_KEY=
API_FOOTBALL_TIMEOUT_MS=10000

# ===============================
# Wallet Worker
# ===============================

WALLET_WORKER_BASE_URL=
WALLET_WORKER_API_KEY=

# ===============================
# FootballTicketNet
# ===============================

FTN_BASE_URL=https://www.footballticketnet.com/api
FTN_USERNAME=
FTN_SECRET_NAME=
FTN_AFFILIATE_SECRET=
FTN_AFFILIATE_ID=yournextaway

# ===============================
# SportsEvents365
# ===============================

# Sandbox:
SE365_BASE_URL=https://api-v2.sandbox365.com

# Live, when approved:
# SE365_BASE_URL=https://api.sportsevents365.com

SE365_API_KEY=
SE365_HTTP_USERNAME=yournextaway
SE365_API_PASSWORD=
SE365_AFFILIATE_ID=69834e80ec9d3

# ===============================
# Gigsberg
# ===============================

GIGSBERG_BASE_URL=https://integration2.gigsberg.com/v2
GIGSBERG_API_KEY=
GIGSBERG_AFFILIATE_ID=yournextaway

# ===============================
# Future Providers (leave blank)
# ===============================

VIAGOGO_API_KEY=
STUBHUB_API_KEY=
TICOMBO_API_KEY=
