# ------------------------------
# YourNextAway Backend ENV file
# ------------------------------
# Copy this file to `.env`
# and fill in your credentials
# ------------------------------

# ===============================
# Server
# ===============================

PORT=3000


# ===============================
# FootballTicketNet
# ===============================

FTN_BASE_URL=https://www.footballticketnet.com/api
FTN_USERNAME=
FTN_SECRET_NAME=
FTN_AFFILIATE_SECRET=
FTN_AFFILIATE_ID=yournextaway


# ===============================
# SportsEvents365
# ===============================

SE365_BASE_URL=https://api.sportsevents365.com
SE365_API_KEY=
SE365_AFFILIATE_ID=


# ===============================
# Gigsberg
# ===============================

GIGSBERG_BASE_URL=https://www.gigsberg.com
GIGSBERG_API_KEY=
GIGSBERG_AFFILIATE_ID=yournextaway


# ===============================
# Future Providers (leave blank)
# ===============================

VIAGOGO_API_KEY=
STUBHUB_API_KEY=
TICOMBO_API_KEY=


# ===============================
# Logging
# ===============================

NODE_ENV=development
