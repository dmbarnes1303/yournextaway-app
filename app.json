{
  "expo": {
    "name": "YourNextAway",
    "slug": "yournextaway",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "yournextaway",

    "icon": "./assets/images/final_quest_240x240.png",
    "userInterfaceStyle": "dark",

    "splash": {
      "image": "./assets/images/final_quest_240x240.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diabloaquila.yournextaway",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.diabloaquila.yournextaway",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/final_quest_240x240.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true
    },

    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/final_quest_240x240.png"
    },

    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "updates": {
      "fallbackToCacheTimeout": 0
    },

    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
