{
  "expo": {
    "name": "YourNextAway",
    "slug": "yournextaway",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "yournextaway",
    "icon": "./assets/images/YNAlogo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/YNAlogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#07120F"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.diabloaquila.yournextaway",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.diabloaquila.yournextaway",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/YNAlogo.png",
        "backgroundColor": "#07120F"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/YNAlogo.png"
    },
    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
