{
  "expo": {
    "name": "Stadiums and Cities",
    "slug": "stadiums-and-cities",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/natively-dark.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "scheme": ["stadiumsandcities"],

    "splash": {
      "image": "./assets/images/natively-dark.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.anonymous.natively",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },

    "android": {
      "package": "com.anonymous.natively",
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/natively-dark.png",
        "backgroundColor": "#000000"
      }
    },

    "web": {
      "favicon": "./assets/images/final_quest_240x240.png",
      "bundler": "metro"
    },

    "plugins": [
      "expo-font",
      "expo-router",
      "expo-web-browser",
      "@react-native-community/datetimepicker"
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "EXPO_PUBLIC_API_FOOTBALL_KEY": "a1385c927f799e0674174b06277d2c22",
      "backendUrl": "https://h5354xkb5ak2jcn98rjgh6tywsyw9qva.app.specular.dev"
    }
  }
}
