# ------------------------------------------------
# YourNextAway Environment Variables Template
# ------------------------------------------------
# Copy this file to `.env` and replace placeholder
# values with your real keys.
# NEVER commit the real `.env` file.
# ------------------------------------------------


# ------------------------------------------------
# API-Football (API-Sports)
# Used for fixtures, teams, leagues etc
# ------------------------------------------------
EXPO_PUBLIC_API_FOOTBALL_KEY=YOUR_API_FOOTBALL_KEY


# ------------------------------------------------
# Backend API
# YourNextAway backend resolver / proxy
# ------------------------------------------------
EXPO_PUBLIC_BACKEND_URL=https://your-backend-url.example.com


# ------------------------------------------------
# Supabase (if enabled)
# Used for auth / database / storage
# ------------------------------------------------
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_PUBLIC_ANON_KEY


# ------------------------------------------------
# Optional: Wallet / ticket services
# (public endpoints only)
# ------------------------------------------------
EXPO_PUBLIC_WALLET_API_BASE=https://wallet-api.example.com
